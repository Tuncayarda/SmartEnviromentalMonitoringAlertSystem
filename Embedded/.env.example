# .env.example — Bu dosyayı .env olarak kopyalayıp kendi değerlerinizi girin.
# .env dosyası .gitignore'a eklenmiştir; asla commit etmeyin.

# Cihaz kimliği
DEVICE_ID=ESP_001

# Wi-Fi
WIFI_SSID=your_wifi_ssid
WIFI_PASSWORD=your_wifi_password

# MQTT broker
MQTT_BROKER=192.168.1.100
MQTT_PORT=1883
MQTT_CLIENT_ID=001
MQTT_TOPIC=sensors
MQTT_USER=
MQTT_PASS=
