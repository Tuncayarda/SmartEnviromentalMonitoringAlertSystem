# .env.example — Bu dosyayı .env olarak kopyalayıp kendi değerlerinizi girin.
# .env dosyası .gitignore'a eklenmiştir; asla commit etmeyin.

# Cihaz kimliği
DEVICE_ID=ESP_001

# Wi-Fi
WIFI_SSID=your_wifi_ssid
WIFI_PASSWORD=your_wifi_password

# MQTT broker
MQTT_BROKER=your-cluster.emqxsl.com
MQTT_PORT=8883
MQTT_CLIENT_ID=001
MQTT_TOPIC=sensors
MQTT_USER=your_username
MQTT_PASS=your_password
